# Firestore Security Rules — Smart Air Quality System

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // [Users Collection]
    // Citizens can read/write their own profile.
    // Admins can read/delete any user.
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // [AQI Records]
    // Citizens can read any record (public data) but only write their own manual entries.
    // Admins have full control.
    match /aqi_records/{recordId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // [Health Recommendations]
    // Publicly readable, writeable only by Admins.
    match /recommendations/{tipId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // [Thresholds & Global Settings]
    // Publicly readable, writeable only by Admins.
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // [Feedback]
    // Citizens can only CREATE feedback.
    // Admins can READ/DELETE feedback.
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && isAdmin();
      allow update: if false;
    }
  }
}

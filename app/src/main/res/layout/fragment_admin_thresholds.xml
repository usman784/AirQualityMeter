<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_admin_thresholds.xml — UC10: Configure Thresholds -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AQI Category Thresholds"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Define the transition points for health alerts."
            android:textColor="@color/color_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- Good -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Good (Max AQI)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/aqi_good"
            app:hintTextColor="@color/aqi_good"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_threshold_good"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="50"
                android:inputType="number"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Moderate -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Moderate (Max AQI)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/aqi_moderate"
            app:hintTextColor="@color/aqi_moderate"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_threshold_moderate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="100"
                android:inputType="number"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Sensitive -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Unhealthy for Sensitive (Max AQI)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/aqi_unhealthy"
            app:hintTextColor="@color/aqi_unhealthy"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_threshold_sensitive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="150"
                android:inputType="number"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Unhealthy -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Unhealthy (Max AQI)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/aqi_very_unhealthy"
            app:hintTextColor="@color/aqi_very_unhealthy"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_threshold_unhealthy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="200"
                android:inputType="number"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Hazardous -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Hazardous (Min AQI)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/aqi_hazardous"
            app:hintTextColor="@color/aqi_hazardous"
            android:layout_marginBottom="32dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_threshold_hazardous"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="301"
                android:inputType="number"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_thresholds"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Configuration"
            app:cornerRadius="14dp"
            android:backgroundTint="@color/color_secondary"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Space android:layout_width="match_parent" android:layout_height="100dp" />

    </LinearLayout>
</ScrollView>

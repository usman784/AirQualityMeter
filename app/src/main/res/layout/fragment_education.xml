<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_education.xml — UC15: Educational Health Guides -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Health Guides"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Learn how to protect yourself"
            android:textColor="@color/color_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- Good -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/color_card"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/aqi_good"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🟢  Good (0-50)" android:textColor="@color/aqi_good" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Air quality is considered satisfactory, and air pollution poses little or no risk. Enjoy your outdoor activities!"
                    android:textColor="@color/white" android:textSize="13sp" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Moderate -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/color_card"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/aqi_moderate"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🟡  Moderate (51-100)" android:textColor="@color/aqi_moderate" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Air quality is acceptable. However, for some pollutants, there may be a moderate health concern for a very small number of people who are unusually sensitive to air pollution."
                    android:textColor="@color/white" android:textSize="13sp" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Unhealthy (Sensitive) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/color_card"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/aqi_sensitive"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🟠  Sensitive Groups (101-150)" android:textColor="@color/aqi_sensitive" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Members of sensitive groups (children, elderly, people with lung disease) may experience health effects. The general public is not likely to be affected."
                    android:textColor="@color/white" android:textSize="13sp" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Unhealthy -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/color_card"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/aqi_unhealthy"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔴  Unhealthy (151-200)" android:textColor="@color/aqi_unhealthy" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Everyone may begin to experience health effects; members of sensitive groups may experience more serious health effects. Reduce outdoor activity."
                    android:textColor="@color/white" android:textSize="13sp" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hazardous -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="80dp"
            app:cardBackgroundColor="@color/color_card"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/aqi_hazardous"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚫  Hazardous (301+)" android:textColor="@color/aqi_hazardous" android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Health alert: everyone may experience more serious health effects. Emergency conditions. Avoid all outdoor physical activity."
                    android:textColor="@color/white" android:textSize="13sp" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

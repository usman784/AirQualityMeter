<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- ── AppBarLayout handles status bar insets correctly ──────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="@color/color_toolbar"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/AppToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/admin_title"
            app:titleTextColor="@color/white"
            app:subtitle="@string/citizens_list"
            app:subtitleTextColor="@color/color_secondary"
            app:menu="@menu/menu_signout" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider" />

    <!-- ── Modern Empty State ─────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="40dp"
        android:visibility="gone">

        <!-- Glowing illustration -->
        <FrameLayout
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp">

            <!-- Outer pulse ring -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:background="@drawable/circle_glow"
                android:alpha="0.25" />

            <!-- Illustration -->
            <ImageView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_empty_citizens"
                android:contentDescription="@string/no_citizens" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/no_citizens"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:layout_marginBottom="12dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_citizens_sub"
            android:textColor="@color/color_hint"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="32dp" />

        <!-- Subtle divider dot row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/circle_glow"
                android:alpha="0.8" />

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/circle_glow" />

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/circle_glow"
                android:alpha="0.8" />
        </LinearLayout>

    </LinearLayout>

    <!-- Citizen list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_citizens"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="12dp" />

</LinearLayout>

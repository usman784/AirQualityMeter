<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_manual_entry.xml — UC03: Manual Data Entry & AI Prediction -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AQI Predictor"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter weather data to predict air quality"
            android:textColor="@color/color_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- Input Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/color_card"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/color_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Temperature -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_temp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Temperature (°C)"
                    app:startIconDrawable="@drawable/ic_refresh"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/color_secondary"
                    app:hintTextColor="@color/color_text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_temp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Humidity -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_humidity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Humidity (%)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/color_secondary"
                    app:hintTextColor="@color/color_text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_humidity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Wind speed -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_wind"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Wind Speed (m/s)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/color_secondary"
                    app:hintTextColor="@color/color_text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_wind"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- PM2.5 (optional) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_pm25"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="PM2.5 concentration µg/m³ (optional)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/color_secondary"
                    app:hintTextColor="@color/color_text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_pm25"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Predict Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_predict"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:text="🔮  Predict AQI"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/color_primary"
            app:cornerRadius="16dp" />

        <!-- Result Card (hidden initially) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="80dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/color_card"
            app:cardCornerRadius="20dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/aqi_good">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp">

                <TextView
                    android:id="@+id/tv_result_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😊"
                    android:textSize="48sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_result_aqi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AQI: —"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_result_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/color_secondary"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_result_advice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_offline_note"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💾 Saved locally — will sync when online"
                    android:textSize="11sp"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:chipBackgroundColor="@color/color_surface_variant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

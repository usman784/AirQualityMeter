<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#330DCAF0" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <!-- Inner fill -->
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50%"
                android:startColor="#331B2D5A"
                android:endColor="#1A0D1B3E" />
            <stroke android:width="2dp" android:color="#800DCAF0" />
        </shape>
    </item>
</layer-list>


<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Splash / Auth Router -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.air.quality.meter.ui.fragments.splash.SplashFragment"
        android:label="Air Quality Meter"
        tools:layout="@layout/fragment_splash">

        <action
            android:id="@+id/action_splash_to_admin"
            app:destination="@id/adminHomeFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_splash_to_citizen"
            app:destination="@id/citizenHomeFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Admin Home — bottom nav host (tabs: Users, Datasets, Thresholds, Health, Activity) -->
    <fragment
        android:id="@+id/adminHomeFragment"
        android:name="com.air.quality.meter.ui.fragments.admin.AdminHomeFragment"
        android:label="Admin Panel"
        tools:layout="@layout/fragment_admin_home">

        <!-- Sign-out goes back to splash -->
        <action
            android:id="@+id/action_admin_to_splash"
            app:destination="@id/splashFragment"
            app:enterAnim="@anim/slide_in_left"
            app:exitAnim="@anim/slide_out_right"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Citizen Home — bottom nav host (tabs: Dashboard, Manual, History, Health, Profile) -->
    <fragment
        android:id="@+id/citizenHomeFragment"
        android:name="com.air.quality.meter.ui.fragments.citizen.CitizenHomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_citizen_home">

        <!-- Sign-out goes back to splash (called from CitizenProfileFragment tab) -->
        <action
            android:id="@+id/action_citizen_to_splash"
            app:destination="@id/splashFragment"
            app:enterAnim="@anim/slide_in_left"
            app:exitAnim="@anim/slide_out_right"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_citizen_to_education"
            app:destination="@id/educationFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_citizen_to_about"
            app:destination="@id/aboutFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/educationFragment"
        android:name="com.air.quality.meter.ui.fragments.support.EducationFragment"
        android:label="Health Guides"
        tools:layout="@layout/fragment_education" />

    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.air.quality.meter.ui.fragments.support.AboutFragment"
        android:label="About"
        tools:layout="@layout/fragment_about" />

</navigation>

<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.AirQuiltyMeter" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_variant</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorSecondaryVariant">@color/color_secondary_variant</item>
        <item name="colorOnSecondary">@color/color_on_secondary</item>
        <item name="android:colorBackground">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_on_surface</item>
        <item name="colorError">@color/color_error</item>
        <item name="colorOnError">@color/color_on_error</item>
        <item name="android:statusBarColor">@color/color_status_bar</item>
        <item name="android:navigationBarColor">@color/color_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.AirQuiltyMeter" parent="Base.Theme.AirQuiltyMeter" />

    <!-- ── FirebaseUI dedicated theme — readable light style ─────────────── -->
    <!-- FirebaseUI renders its own Activity, so we give it a clean theme     -->
    <!-- with proper contrast: dark navy bg, white text, cyan accent          -->
    <style name="FirebaseAuthUITheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_secondary</item>
        <item name="colorPrimaryDark">@color/color_secondary_variant</item>
        <item name="colorAccent">@color/color_secondary</item>
        <item name="colorButtonNormal">@color/color_secondary</item>
        <item name="android:colorBackground">#0B1638</item>
        <item name="colorSurface">#111D45</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#99B4D4</item>
        <item name="android:textColorHint">#607090</item>
        <item name="android:windowBackground">@color/color_surface</item>
        <item name="android:statusBarColor">@color/color_status_bar</item>
        <item name="android:navigationBarColor">@color/color_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="editTextStyle">@style/FirebaseEditTextStyle</item>
    </style>

    <style name="FirebaseEditTextStyle" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">#607090</item>
    </style>

    <!-- Modern Toolbar style -->
    <style name="AppToolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/color_toolbar</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">@color/color_secondary</item>
        <item name="android:elevation">0dp</item>
        <item name="actionMenuTextColor">@color/color_secondary</item>
        <item name="android:theme">@style/ToolbarThemeOverlay</item>
        <item name="popupTheme">@style/ToolbarPopupTheme</item>
    </style>

    <!-- Forces menu item text to be white in toolbar -->
    <style name="ToolbarThemeOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/color_secondary</item>
        <item name="actionMenuTextColor">@color/color_secondary</item>
        <item name="colorControlNormal">@color/white</item>
    </style>

    <!-- Popup menu style when toolbar menu items are clicked -->
    <style name="ToolbarPopupTheme" parent="ThemeOverlay.Material3.Light">
        <item name="android:textColorPrimary">@color/color_surface</item>
    </style>

    <!-- Glassmorphism Card style -->
    <style name="CitizenCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/color_card</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">8dp</item>
        <item name="contentPadding">0dp</item>
        <item name="strokeColor">@color/color_card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Elevated profile card -->
    <style name="ProfileCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/color_surface</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">12dp</item>
        <item name="contentPadding">0dp</item>
        <item name="strokeColor">@color/glow_cyan</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Modern outlined input style -->
    <style name="ProfileInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/color_secondary</item>
        <item name="hintTextColor">@color/color_secondary</item>
        <item name="android:textColorHint">@color/color_hint</item>
        <item name="boxBackgroundColor">@color/color_surface</item>
        <item name="shapeAppearanceOverlay">@style/RoundedInputShape</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <style name="RoundedInputShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <!-- Neon Chip style -->
    <style name="NeonChip" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/color_surface_variant</item>
        <item name="chipStrokeColor">@color/color_secondary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/color_secondary</item>
        <item name="chipCornerRadius">8dp</item>
    </style>

    <!-- Admin list item style -->
    <style name="AdminListItem">
        <item name="android:background">@drawable/item_card_ripple</item>
        <item name="android:padding">0dp</item>
    </style>
</resources>